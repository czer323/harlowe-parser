{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "declaration": true,
        "declarationDir": "./types",
        "isolatedModules": true,
        "types": [
            "vitest/globals"
        ]
    },
    "include": [
        "src",
        "tests",
        "scripts"
    ]
}